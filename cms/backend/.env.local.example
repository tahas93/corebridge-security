# Copy to .env.local for local development
NODE_ENV=development
PORT=4000

DATABASE_URL=postgresql://cms:cms_secret@localhost:5432/corebridge_cms?schema=public
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50
WEBSITE_PREVIEW_SECRET=preview-secret-change-me
SEED_ADMIN_EMAIL=admin@corebridge.security
SEED_ADMIN_PASSWORD=ChangeMe!Secure123
